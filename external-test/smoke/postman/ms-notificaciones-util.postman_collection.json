                },
                "url": {
                  "raw": "{{baseUrl}}/notificarCorreo",
                  "host": ["{{baseUrl}}"],
                  "path": ["notificarCorreo"]
                }
              },
              "status": "No Content",
              "code": 204,
              "_postman_previewlanguage": "text",
              "header": [],
              "body": ""
            }
