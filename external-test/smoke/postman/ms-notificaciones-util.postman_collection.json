{
  "info": {
    "_postman_id": "617fbbaa-d0c7-48d4-9e3d-cb19da296990",
    "name": "ms-notificaciones-util",
    "description": "Smoke tests para el microservicio ms-notificaciones-util.\n\n**Base URL:** `{{baseUrl}}`  (default: `http://localhost:8055/securityapi`)\n\n**Autenticación:** Bearer JWT. Asigna el token en la variable de colección `jwtToken` antes de ejecutar.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8055/securityapi",
      "type": "string",
      "description": "URL base del microservicio (incluye context-path)"
    },
    {
      "key": "jwtToken",
      "value": "",
      "type": "string",
      "description": "JWT Bearer token con rol ADMINISTRADOR, EMPRESA, OPERARIO o FONDEADOR"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwtToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Notificaciones Correo",
      "description": "Operaciones de envío de correos electrónicos vía SMTP — endpoint POST /notificarCorreo",
      "item": [
        {
          "name": "Enviar correo HTML — 204 OK",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 204 No Content', function () {",
                  "    pm.response.to.have.status(204);",
                  "});",
                  "pm.test('Body vacío en respuesta exitosa', function () {",
                  "    pm.expect(pm.response.text()).to.be.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombreRemitente\": \"Plataforma Factoring\",\n  \"correoRemitente\": \"notificaciones@factoring.co.com\",\n  \"asunto\": \"Instrucción de pago #INS-2024-001\",\n  \"destinatarios\": [\n    \"empresa@cliente.com\"\n  ],\n  \"destinatariosCc\": [\n    \"supervisor@factoring.co.com\"\n  ],\n  \"destinatariosBcc\": [\n    \"auditoria@factoring.co.com\"\n  ],\n  \"cuerpoHtml\": \"<h1>Instrucción procesada</h1><p>Estimado cliente, su instrucción de pago ha sido procesada exitosamente.</p>\",\n  \"firma\": \"Equipo Factoring | www.factoring.co.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/notificarCorreo",
              "host": ["{{baseUrl}}"],
              "path": ["notificarCorreo"]
            },
            "description": "Envía un correo con cuerpo HTML, CC y BCC. Espera respuesta 204 No Content."
          },
          "response": [
            {
              "name": "204 No Content — Correo enviado",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{jwtToken}}"
                  }
