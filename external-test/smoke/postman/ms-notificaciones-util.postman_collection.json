                  "});",
                  "pm.test('Respuesta contiene campo status', function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body).to.have.property('status');",
                  "    pm.expect(body.status).to.eql(401);",
                  "});"
                ]
