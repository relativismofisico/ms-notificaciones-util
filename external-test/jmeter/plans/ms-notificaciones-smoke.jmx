          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script"><![CDATA[
vars.put("jwt_admin",     props.get("jwt.token.admin")     ?: "")
vars.put("jwt_empresa",   props.get("jwt.token.empresa")   ?: "")
vars.put("jwt_sinacceso", props.get("jwt.token.sinacceso") ?: "")
def len = vars.get("jwt_admin")?.length() ?: 0
log.info("[Config] jwt_admin length=" + len + (len > 0 ? " OK" : " VACIO!"))
SampleResult.setSuccessful(true)
SampleResult.setResponseMessage("JWT vars cargadas desde props")
          ]]></stringProp>
        </JSR223Sampler>
        <hashTree/>

